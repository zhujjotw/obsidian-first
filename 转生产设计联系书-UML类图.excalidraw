			"fontSize": 12,
			"fontFamily": 1,
			"text": "PLMClient (PLM API客户端)\nplm_utils.py (444行)\n────────────────────────────────\n────\n属性:\n  - base_url: str\n  - user_key: str\n  - product_info_key: str\n  - session: requests.Session\n────────────────────────────────\n────\n联系书相关方法:\n  + get_production_design_contact_letters_list()\n    -> dict\n  + get_contact_letter_detail_info(id: str) -> dict\n  + create_design_contact_letter(data: dict) -> dict\n  + inquire_latest_contact_letter_without_draft()\n    -> dict\n────────────────────────────────\n────\n测试申请单相关方法:\n  + get_test_request_list(project: str) -> dict\n  + get_test_request_detail_info(name: str) -> dict\n  + get_latest_test_request(project: str) -> str\n────────────────────────────────\n────\n产品信息方法:\n  + get_product_info(project: str) -> dict\n  + get_soft_material(project: str) -> dict\n  + queryDdrAndEmmcForModel(model: str) -> dict\n────────────────────────────────\n────\n物料相关方法:\n  + getMaterialAllAttribute(material_id: str) -> dict\n────────────────────────────────\n────\n项目相关方法:\n  + getProjectMember(project: str) -> dict\n  + getRelHISTestProjectToProject(project: str) -> dict\n────────────────────────────────\n────\n辅助类:\n  PLMConfig\n    - base_url: str\n    - user_key: str",
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": "class-plmClient",
